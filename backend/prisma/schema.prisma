// Schema do banco de dados - Smash Club
// Local (dev): SQLite, um arquivo unico, sem instalar nada.
// Producao: troque o provider abaixo para "postgresql" e o DATABASE_URL no .env

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// SQLite nao suporta o tipo "enum" nativo do Prisma, entao guardamos o papel
// do usuario como texto ("PLAYER" ou "CLUB_OWNER"). A validacao de que so
// esses dois valores sao aceitos continua sendo feita no codigo (Zod).

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  playerProfile PlayerProfile?
  clubProfile   ClubProfile?
  bookings      Booking[]
  matchParticipations MatchParticipant[]
}

// Perfil especifico de jogador - so existe se o User tiver role = PLAYER
model PlayerProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentLevel       Float    @default(2.0)
  reliability        Int      @default(20) // 0-100, confianca no nivel atual
  preferredPosition  String?  // "drive" | "reves" | "ambos"
  racketBrand        String?
  racketModel        String?
  city               String?
  state              String?
  createdAt          DateTime @default(now())

  levelHistory       LevelHistoryEntry[]
}

// Registo de cada ajuste de nivel (questionario inicial ou pos-partida)
model LevelHistoryEntry {
  id                  String   @id @default(uuid())
  playerProfileId     String
  playerProfile       PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  levelBefore         Float
  levelAfter          Float
  reliabilityBefore   Int
  reliabilityAfter    Int
  delta               Float
  reason              String   // "questionario" | "partida"
  summary             String   // texto explicativo curto

  createdAt           DateTime @default(now())
}

// Perfil especifico de dono de arena - so existe se o User tiver role = CLUB_OWNER
model ClubProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String?
  phone        String?
  createdAt    DateTime @default(now())

  arenas       Arena[]
}

// Uma arena pertence a um ClubProfile (o dono). Tem varias quadras (courts).
model Arena {
  id           String   @id @default(uuid())
  ownerId      String
  owner        ClubProfile @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  address      String
  city         String
  state        String
  latitude     Float?
  longitude    Float?

  // SQLite nao tem um tipo nativo de lista, entao guardamos como texto
  // separado por virgula, ex: "estacionamento,bar,vestiario,loja"
  amenities    String   @default("")
  // Mesma logica para as fotos: URLs separadas por virgula
  photos       String   @default("")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  courts       Court[]
}

// Cada quadra pertence a uma Arena
model Court {
  id             String  @id @default(uuid())
  arenaId        String
  arena          Arena   @relation(fields: [arenaId], references: [id], onDelete: Cascade)

  name           String  // ex: "Quadra 1"
  type           String  // "coberta" | "descoberta"
  surface        String  // "vidro" | "alvenaria"
  basePriceHour  Float

  createdAt      DateTime @default(now())

  bookings       Booking[]
}

// Uma reserva de horario, feita por um jogador, numa quadra especifica
model Booking {
  id          String   @id @default(uuid())

  courtId     String
  court       Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  playerId    String
  player      User     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  startsAt    DateTime
  endsAt      DateTime
  totalPrice  Float

  // "confirmed" | "cancelled"
  status      String   @default("confirmed")

  // Jogo aberto: outros jogadores podem enxergar/entrar nesse horário
  isOpenMatch      Boolean @default(false)
  maxPlayers       Int     @default(4)
  minLevel         Float?
  maxLevel         Float?
  invitedEmails    String  @default("")

  participants     MatchParticipant[]

  createdAt   DateTime @default(now())
}

// Participante de um jogo aberto (diferente do organizador, que ja esta em Booking.playerId)
model MatchParticipant {
  id         String   @id @default(uuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  playerId   String
  player     User     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  joinedAt   DateTime @default(now())

  @@unique([bookingId, playerId]) // um jogador nao pode entrar duas vezes
}
