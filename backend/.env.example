# Copie este arquivo para ".env" e ajuste os valores.
# Comando: cp .env.example .env   (Mac/Linux)  ou  copy .env.example .env  (Windows)

# Banco de dados local (arquivo SQLite, criado automaticamente)
DATABASE_URL="file:./dev.db"

# Segredo usado para assinar os tokens JWT.
# Troque por um valor aleatorio e longo antes de ir para producao.
JWT_SECRET="troque-este-valor-por-uma-string-aleatoria-bem-longa"

# Por quanto tempo o token de login fica valido
JWT_EXPIRES_IN="7d"

# Porta em que a API vai rodar localmente
PORT=3333
